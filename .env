# Port to run the server on
PORT=3000

# Stripe Credentials
# Place your Stripe Secret Key here (sk_live_...)
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE

# Vercel or Production Domain URL (for success/cancel redirects)
PRODUCTION_URL=https://focldow.vercel.app

# Stripe Webhook Secret (Obtain from Stripe CLI or Dashboard when configuring webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
